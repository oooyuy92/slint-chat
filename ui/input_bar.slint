export component InputBar inherits Rectangle {
    in property <bool> sending: false;
    in property <string> current-model: "";
    callback send(string);
    callback toggle-model-selector();

    property <string> input-text: "";

    background: #ffffff;

    VerticalLayout {
        padding-top: 8px;
        padding-bottom: 20px;
        padding-left: 24px;
        padding-right: 24px;

        // Outer container — prompt-input card style
        Rectangle {
            max-width: 768px;
            horizontal-stretch: 1;
            border-radius: 24px;
            border-width: 1px;
            border-color: #e0e0e0;
            background: #ffffff;
            drop-shadow-blur: 4px;
            drop-shadow-color: #00000008;
            drop-shadow-offset-y: 1px;

            VerticalLayout {
                padding: 8px;

                // Body — textarea area (layered, not stacked)
                body-ta := TouchArea {
                    horizontal-stretch: 1;
                    height: 44px;
                    vertical-stretch: 0;
                    clicked => { input.focus(); }

                    Rectangle {
                        input := TextInput {
                            x: 8px;
                            y: 0;
                            width: parent.width - 16px;
                            height: parent.height;
                            text <=> root.input-text;
                            enabled: !root.sending;
                            font-size: 15px;
                            color: #0d0d0d;
                            vertical-alignment: center;

                            accepted => {
                                if root.input-text != "" {
                                    root.send(root.input-text);
                                    root.input-text = "";
                                }
                            }
                        }
                    }
                }

                // Footer — tools left, submit right
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 4px;
                    padding-top: 2px;

                    // Tools — left side
                    HorizontalLayout {
                        horizontal-stretch: 1;
                        spacing: 4px;
                        alignment: start;

                        // Model selector pill button
                        model-ta := TouchArea {
                            height: 32px;
                            mouse-cursor: pointer;
                            clicked => { root.toggle-model-selector(); }

                            Rectangle {
                                background: model-ta.has-hover ? #f4f4f5 : transparent;
                                border-radius: 16px;

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 6px;

                                    Text {
                                        text: "✦";
                                        font-size: 12px;
                                        color: #6b7280;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.current-model != "" ? root.current-model : "选择模型";
                                        font-size: 13px;
                                        color: #6b7280;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Submit button — right side
                    send-ta := TouchArea {
                        width: 32px;
                        height: 32px;
                        enabled: !root.sending && root.input-text != "";
                        mouse-cursor: root.input-text != "" && !root.sending ? pointer : default;
                        clicked => {
                            if root.input-text != "" {
                                root.send(root.input-text);
                                root.input-text = "";
                            }
                        }

                        Rectangle {
                            background: root.sending ? #d1d5db
                                      : root.input-text == "" ? #d1d5db
                                      : send-ta.has-hover ? #2d2d2d
                                      : #0d0d0d;
                            border-radius: 16px;

                            Text {
                                text: root.sending ? "■" : "↑";
                                color: #ffffff;
                                font-size: 16px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
