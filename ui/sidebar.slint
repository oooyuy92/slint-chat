export struct TopicItem {
    id: string,
    title: string,
}

export component Sidebar inherits Rectangle {
    in property <[TopicItem]> topics;
    in-out property <int> active-index: -1;
    callback topic-selected(int);
    callback new-topic();
    callback open-settings();

    width: 240px;
    background: #f9f9f9;

    VerticalLayout {
        padding: 8px;
        spacing: 2px;

        // New chat button
        new-btn-ta := TouchArea {
            height: 44px;
            clicked => { root.new-topic(); }

            Rectangle {
                background: new-btn-ta.has-hover ? #efefef : transparent;
                border-radius: 8px;

                HorizontalLayout {
                    padding-left: 12px;
                    spacing: 10px;

                    Text {
                        text: "✏";
                        font-size: 15px;
                        color: #0d0d0d;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "新对话";
                        color: #0d0d0d;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 8px; }

        for topic[i] in root.topics : item-ta := TouchArea {
            height: 36px;
            clicked => {
                root.active-index = i;
                root.topic-selected(i);
            }

            Rectangle {
                background: root.active-index == i ? #e8e8e8
                          : item-ta.has-hover ? #efefef
                          : transparent;
                border-radius: 8px;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 8px;
                    Text {
                        text: topic.title;
                        color: #0d0d0d;
                        font-size: 14px;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Spacer to push settings to bottom
        Rectangle { vertical-stretch: 1; }

        // Settings button
        settings-ta := TouchArea {
            height: 40px;
            clicked => { root.open-settings(); }

            Rectangle {
                background: settings-ta.has-hover ? #efefef : transparent;
                border-radius: 8px;

                HorizontalLayout {
                    padding-left: 12px;
                    spacing: 10px;

                    Text {
                        text: "⚙";
                        font-size: 15px;
                        color: #6e6e80;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "设置";
                        color: #6e6e80;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
