export enum BlockType {
    Paragraph,
    CodeBlock,
    Heading1,
    Heading2,
    Heading3,
    ListItem,
    HorizontalRule,
}

export struct MarkdownBlock {
    block-type: BlockType,
    text: string,
    lang: string,
}

export component MarkdownView {
    in property <[MarkdownBlock]> blocks;

    VerticalLayout {
        spacing: 10px;
        alignment: start;

        for block[i] in root.blocks : VerticalLayout {
            if block.block-type == BlockType.Paragraph : Text {
                text: block.text;
                wrap: word-wrap;
                color: #0d0d0d;
                font-size: 15px;

            }

            if block.block-type == BlockType.Heading1 : Text {
                text: block.text;
                wrap: word-wrap;
                color: #0d0d0d;
                font-size: 22px;
                font-weight: 700;
            }

            if block.block-type == BlockType.Heading2 : Text {
                text: block.text;
                wrap: word-wrap;
                color: #0d0d0d;
                font-size: 18px;
                font-weight: 700;
            }

            if block.block-type == BlockType.Heading3 : Text {
                text: block.text;
                wrap: word-wrap;
                color: #0d0d0d;
                font-size: 16px;
                font-weight: 600;
            }

            if block.block-type == BlockType.ListItem : HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text { text: "•"; color: #0d0d0d; font-size: 15px; }
                Text {
                    text: block.text;
                    wrap: word-wrap;
                    color: #0d0d0d;
                    font-size: 15px;
    
                }
            }

            if block.block-type == BlockType.CodeBlock : Rectangle {
                background: #1e1e1e;
                border-radius: 8px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 6px;

                    if block.lang != "" : Text {
                        text: block.lang;
                        color: #8b8b8b;
                        font-size: 12px;
                    }

                    Text {
                        text: block.text;
                        font-family: "monospace";
                        font-size: 13px;
                        color: #d4d4d4;
                        wrap: no-wrap;
                    }
                }
            }

            if block.block-type == BlockType.HorizontalRule : Rectangle {
                height: 1px;
                background: #e5e5e5;
            }
        }
    }
}
