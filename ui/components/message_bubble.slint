import { MarkdownView, MarkdownBlock, BlockType } from "markdown_view.slint";
import { ReasoningView } from "reasoning_view.slint";

export struct MessageItem {
    is-user: bool,
    content: string,
    blocks: [MarkdownBlock],
    reasoning: string,
    reasoning-streaming: bool,
}

export component MessageBubble inherits VerticalLayout {
    in property <MessageItem> message;
    in property <bool> is-streaming: false;

    // User message: right-aligned, light secondary background, rounded
    if root.message.is-user : HorizontalLayout {
        alignment: end;

        Rectangle {
            background: #f4f4f5;
            border-radius: 10px;
            max-width: 520px;

            VerticalLayout {
                padding-top: 10px;
                padding-bottom: 10px;
                padding-left: 16px;
                padding-right: 16px;

                Text {
                    text: root.message.content;
                    wrap: word-wrap;
                    color: #0d0d0d;
                    font-size: 14px;
                }
            }
        }
    }

    // AI message: reasoning + markdown content
    if !root.message.is-user : VerticalLayout {
        spacing: 8px;

        // Reasoning section (collapsible)
        ReasoningView {
            content: root.message.reasoning;
            is-streaming: root.message.reasoning-streaming;
        }

        // Main content
        MarkdownView {
            blocks: root.message.blocks;
        }
    }
}
